---
import FormattedDate from '@components/FormattedDate.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  url: string;
  description?: string;
  excerpt?: string;
}

const { title, date, tags, url, description, excerpt } = Astro.props;
const displayText = excerpt || description || '';
---

<article class="post-card group">
  <a href={url} class="absolute inset-0 z-10" aria-label={title}></a>
  <div class="flex flex-col gap-2">
    <h2 class="text-lg font-semibold tracking-tight transition-colors group-hover:text-accent dark:group-hover:text-accent-light" style="color: rgb(var(--color-fg));">
      {title}
    </h2>

    <div class="flex items-center gap-2 text-xs" style="color: rgb(var(--color-muted));">
      <FormattedDate date={date} />
      {tags.length > 0 && (
        <>
          <span>&middot;</span>
          <div class="flex flex-wrap gap-1.5">
            {tags.slice(0, 3).map((tag) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
        </>
      )}
    </div>

    {displayText && (
      <p class="mt-1 line-clamp-2 text-sm leading-relaxed" style="color: rgb(var(--color-muted));">
        {displayText}
      </p>
    )}
  </div>
</article>
