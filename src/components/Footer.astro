---
import { SITE } from '@/config';

const currentYear = new Date().getFullYear();
const startYear = SITE.startYear;
const yearRange = startYear === currentYear ? `${currentYear}` : `${startYear} - ${currentYear}`;
---

<footer class="border-t py-8 mt-16" style="border-color: rgb(var(--color-border));">
  <div class="container-wide flex flex-col items-center gap-4 text-sm" style="color: rgb(var(--color-muted));">
    <!-- Social Links -->
    <div class="flex items-center gap-4">
      <a href={SITE.social.github} target="_blank" rel="noopener" class="transition-colors hover:text-accent dark:hover:text-accent-light" aria-label="GitHub">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>
      <a href={`mailto:${SITE.social.email}`} class="transition-colors hover:text-accent dark:hover:text-accent-light" aria-label="Email">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
      <a href="/rss.xml" class="transition-colors hover:text-accent dark:hover:text-accent-light" aria-label="RSS">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20a2.18 2.18 0 110-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
        </svg>
      </a>
    </div>

    <!-- Copyright -->
    <div class="text-center">
      <p>
        &copy; {yearRange} {SITE.title}
        <span class="mx-1.5">&middot;</span>
        Powered by <a href="https://astro.build" target="_blank" rel="noopener" class="transition-colors hover:text-accent dark:hover:text-accent-light">Astro</a>
      </p>
      <p id="footer-runtime" class="mt-1 text-xs"></p>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    const start = new Date('2024/11/12 11:40:14').getTime();
    const now = Date.now();
    const diff = now - start;
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const el = document.getElementById('footer-runtime');
    if (el) el.textContent = `已运行 ${days} 天 ${hours} 小时 ${mins} 分钟`;
  })();
</script>
