---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="页面未找到">
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-5 text-center">
    <p class="text-7xl font-bold text-accent dark:text-accent-light">404</p>
    <h1 class="mt-4 text-2xl font-semibold" style="color: rgb(var(--color-fg));">页面未找到</h1>
    <p class="mt-2 text-sm" style="color: rgb(var(--color-muted));">你访问的页面不存在或已被移动</p>
    <a
      href="/"
      class="mt-6 rounded-lg border px-5 py-2.5 text-sm font-medium transition-colors hover:border-accent/40 hover:text-accent dark:hover:text-accent-light"
      style="border-color: rgb(var(--color-border)); color: rgb(var(--color-fg));"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
